#include <iostream>
#include <map>
#include <set>
#include <string> 
#include <vector>

using namespace std;

int main() {
    int numStates, numSymbols, numTransitions;
    // Use string for states so you can type 'q0', 'q1', etc.
    string initialState; 
    map<pair<string, char>, string> transition;
    set<string> finalStates;

    cout << "Enter number of input symbols: ";
    cin >> numSymbols;
    vector<char> symbols(numSymbols);
    cout << "Enter symbols (e.g., a b): ";
    for (int i = 0; i < numSymbols; i++) cin >> symbols[i];

    cout << "Enter total number of transitions to define: ";
    cin >> numTransitions;

    cout << "Enter transitions (current_state symbol next_state):\n";
    for (int i = 0; i < numTransitions; i++) {
        string s1, s2;
        char sym;
        cin >> s1 >> sym >> s2;
        transition[{s1, sym}] = s2;
    }

    cout << "Enter initial state (e.g., q0): ";
    cin >> initialState;

    int nFinal;
    cout << "Enter number of final states: ";
    cin >> nFinal;
    cout << "Enter final states: ";
    for (int i = 0; i < nFinal; i++) {
        string fs;
        cin >> fs;
        finalStates.insert(fs);
    }

    string inputStr;
    cout << "\nEnter input string to test: ";
    cin >> inputStr;

    string currentState = initialState;
    bool failed = false;

    for (char ch : inputStr) {
        if (transition.find({currentState, ch}) == transition.end()) {
            failed = true;
            break;
        }
        currentState = transition[{currentState, ch}];
    }

    if (!failed && finalStates.count(currentState)) {
        cout << "RESULT: Accepted" << endl;
    } else {
        cout << "RESULT: Rejected" << endl;
    }

    return 0;
}
